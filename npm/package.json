{
  "name": "ai-knot",
  "version": "0.11.0",
  "description": "Deterministic, self-hosted AI agent memory for TypeScript apps via MCP, HTTP sidecars, and the Vercel AI SDK",
  "license": "MIT",
  "author": "Oleg",
  "homepage": "https://github.com/alsoleg89/ai-knot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/alsoleg89/ai-knot.git",
    "directory": "npm"
  },
  "bugs": {
    "url": "https://github.com/alsoleg89/ai-knot/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "agent-memory",
    "ai-memory",
    "long-term-memory",
    "mcp",
    "model-context-protocol",
    "typescript",
    "javascript",
    "vercel-ai-sdk",
    "ai-sdk",
    "openclaw"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "bin": {
    "ai-knot-demo": "./scripts/demo.mjs",
    "ai-knot-doctor": "./scripts/doctor.mjs"
  },
  "files": [
    "dist/",
    "scripts/demo.mjs",
    "scripts/doctor.mjs",
    "scripts/postinstall.js",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.build.json --outDir dist/esm",
    "build:cjs": "tsc -p tsconfig.build.json --outDir dist/cjs --module commonjs --moduleResolution node && node --input-type=module -e \"import{writeFileSync}from'node:fs';writeFileSync('dist/cjs/package.json',JSON.stringify({type:'commonjs'}))\"",
    "example:basic-memory-loop": "node --import tsx examples/basic-memory-loop.ts",
    "example:http-sidecar": "node --import tsx examples/http-sidecar.ts",
    "example:vercel-ai-sdk": "node --import tsx examples/vercel-ai-sdk.ts",
    "example:vercel-ai-sdk-surface": "node --import tsx examples/vercel-ai-sdk-surface.ts",
    "doctor": "node scripts/doctor.mjs",
    "package:audit": "node scripts/package-audit.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "node --input-type=module -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall.js"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^4.0.4",
    "@types/node": "^25.5.0",
    "ai": "^7.0.9",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
