{
  "name": "longmemevalbench",
  "version": "0.1.0",
  "private": true,
  "description": "LongMemEval benchmark for ai-knot (LLM-judge, checkpoint-resume, multi-agent)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bench": "node --import tsx src/index.ts run -r default",
    "bench:sample": "node --import tsx src/index.ts run -r sample --data data/sample_longmemeval.json",
    "list": "node --import tsx src/index.ts list"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "ai": "^4.3.0",
    "ai-knot": "file:../npm"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
