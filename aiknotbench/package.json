{
  "name": "aiknotbench",
  "version": "0.1.0",
  "private": true,
  "description": "LoCoMo benchmark for ai-knot (LLM-judge, checkpoint-resume)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bench": "bun run src/index.ts run -r default",
    "bench:full": "bun run src/index.ts run -r full --types 1,2,3,4",
    "bench:quick": "bun run src/index.ts run -r quick --limit 2 --types 1,2",
    "bench:sample": "bun run src/index.ts run -r sample --sample 5",
    "list": "bun run src/index.ts list"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "ai": "^4.3.0",
    "ai-knot": "file:../npm"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
