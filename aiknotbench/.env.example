# ── LLM backend (pick one) ────────────────────────────────────────────────────

# Option A: Ollama (local, no key required)
OLLAMA_BASE_URL=http://localhost:11434/v1
DEFAULT_JUDGE_MODEL=ollama:qwen2.5:7b
DEFAULT_ANSWER_MODEL=ollama:qwen2.5:7b

# Option B: OpenAI
# OPENAI_API_KEY=sk-...
# DEFAULT_JUDGE_MODEL=gpt-4o-mini
# DEFAULT_ANSWER_MODEL=gpt-4o
# AI_KNOT_PROVIDER=openai
# AI_KNOT_MODEL=gpt-4o-mini
# AI_KNOT_EMBED_URL=https://api.openai.com
# AI_KNOT_EMBED_MODEL=text-embedding-3-small
# (AI_KNOT_EMBED_API_KEY falls back to OPENAI_API_KEY automatically)

# Option C: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_JUDGE_MODEL=claude-3-5-haiku-20241022
# DEFAULT_ANSWER_MODEL=claude-3-5-sonnet-20241022

# ── Dataset ───────────────────────────────────────────────────────────────────

# Optional: skip download by pointing to a local copy
# LOCOMO_FILE=/path/to/locomo10.json

# ── ai-knot ───────────────────────────────────────────────────────────────────

# Path to ai-knot-mcp binary (default: ai-knot-mcp on PATH)
# AI_KNOT_COMMAND=/path/to/.venv/bin/ai-knot-mcp
